# Generate both with: pnpm env:setup-dev
CLIENT_ASSERTION_KEY=
COOKIE_SECRET=

# Set to your tunnel URL to use a confidential client in dev
# OAUTH_PUBLIC_URL=https://your-tunnel.trycloudflare.com

# Community authorities for multi-authority dispatch (pipe-delimited, comma-separated)
# Format: endpoint|serviceDid|namespace[,endpoint|serviceDid|namespace,...]
# COMMUNITY_AUTHORITIES=http://localhost:3000|did:web:community.atmo.rsvp|rsvp.atmo
