{
  "lexicon": 1,
  "id": "app.bsky.actor.profile",
  "defs": {
    "main": {
      "type": "record",
      "description": "Spike: minimal app.bsky.actor.profile record lexicon so HappyView will ingest/backfill profile records. Only the fields atmo reads (displayName, avatar) plus common ones.",
      "key": "literal:self",
      "record": {
        "type": "object",
        "properties": {
          "displayName": { "type": "string", "maxGraphemes": 64, "maxLength": 640 },
          "description": { "type": "string", "maxGraphemes": 256, "maxLength": 2560 },
          "avatar": { "type": "blob", "accept": ["image/png", "image/jpeg"], "maxSize": 1000000 },
          "banner": { "type": "blob", "accept": ["image/png", "image/jpeg"], "maxSize": 1000000 },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
